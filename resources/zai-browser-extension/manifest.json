{
  "manifest_version": 3,
  "name": "WebAgent z.ai Bridge",
  "description": "Bridge content script for local no-API z.ai automation.",
  "version": "0.1.0",
  "permissions": ["tabs", "storage", "alarms"],
  "host_permissions": ["https://chat.z.ai/*", "ws://127.0.0.1/*", "ws://localhost/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "WebAgent z.ai Bridge"
  },
  "content_scripts": [
    {
      "matches": ["https://chat.z.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}

