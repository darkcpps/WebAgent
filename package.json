{
  "name": "webagent-code",
  "displayName": "WebAgent Code",
  "description": "Use website-based AI chat providers as agentic coding assistants inside VS Code.",
  "version": "0.1.0",
  "publisher": "local",
  "license": "MIT",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:webagentCode.open",
    "onView:webagentCode.sessions",
    "onView:webagentCode.activity",
    "onView:webagentCode.mcp"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "webagentCode.open",
        "title": "WebAgent Code: Open Panel"
      },
      {
        "command": "webagentCode.startTask",
        "title": "WebAgent Code: Start Task"
      },
      {
        "command": "webagentCode.stopTask",
        "title": "WebAgent Code: Stop Task"
      },
      {
        "command": "webagentCode.loginProvider",
        "title": "WebAgent Code: Login to Provider"
      },
      {
        "command": "webagentCode.resetConversation",
        "title": "WebAgent Code: Reset Provider Conversation"
      },
      {
        "command": "webagentCode.listMcpTools",
        "title": "WebAgent Code: List MCP Tools"
      },
      {
        "command": "webagentCode.refreshMcpServers",
        "title": "WebAgent Code: Refresh MCP Servers"
      },
      {
        "command": "webagentCode.disableMcpServer",
        "title": "WebAgent Code: Disable MCP Server",
        "icon": "$(circle-slash)"
      },
      {
        "command": "webagentCode.enableMcpServer",
        "title": "WebAgent Code: Enable MCP Server",
        "icon": "$(check)"
      },
      {
        "command": "webagentCode.approvePendingAction",
        "title": "WebAgent Code: Approve Pending Action"
      },
      {
        "command": "webagentCode.rejectPendingAction",
        "title": "WebAgent Code: Reject Pending Action"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "webagentCode",
          "title": "WebAgent Code",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "webagentCode": [
        {
          "id": "webagentCode.sessions",
          "name": "Sessions"
        },
        {
          "id": "webagentCode.activity",
          "name": "Activity"
        },
        {
          "id": "webagentCode.mcp",
          "name": "MCP Servers"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "webagentCode.refreshMcpServers",
          "when": "view == webagentCode.mcp",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "webagentCode.disableMcpServer",
          "when": "view == webagentCode.mcp && viewItem == mcpServerEnabled",
          "group": "inline"
        },
        {
          "command": "webagentCode.enableMcpServer",
          "when": "view == webagentCode.mcp && viewItem == mcpServerDisabled",
          "group": "inline"
        },
        {
          "command": "webagentCode.approvePendingAction",
          "when": "view == webagentCode.activity && viewItem == pendingAction",
          "group": "inline"
        },
        {
          "command": "webagentCode.rejectPendingAction",
          "when": "view == webagentCode.activity && viewItem == pendingAction",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "WebAgent Code",
      "properties": {
        "webagentCode.approvalMode": {
          "type": "string",
          "enum": [
            "view-only",
            "ask-before-action",
            "auto-apply-safe-edits"
          ],
          "default": "ask-before-action",
          "description": "Controls when WebAgent Code asks for approval before performing actions."
        },
        "webagentCode.maxFiles": {
          "type": "number",
          "default": 500,
          "minimum": 10,
          "maximum": 10000,
          "description": "Maximum number of workspace files to consider while building repo context. Auto-scales with detected codebase tier."
        },
        "webagentCode.searchScanLimit": {
          "type": "number",
          "default": 200,
          "minimum": 10,
          "description": "Maximum number of ranked workspace files to open during each Agent Mode text search. Auto-scales with detected codebase tier."
        },
        "webagentCode.includeHiddenFiles": {
          "type": "boolean",
          "default": false,
          "description": "Whether hidden files should be considered during repo scans."
        },
        "webagentCode.useRipgrep": {
          "type": "boolean",
          "default": true,
          "description": "Use ripgrep for fast file search when available. Falls back to naive search if ripgrep is not found."
        },
        "webagentCode.excludePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional glob patterns to exclude from file discovery, beyond .gitignore and built-in excludes."
        },
        "webagentCode.codebaseTier": {
          "type": "string",
          "enum": [
            "auto",
            "small",
            "medium",
            "large",
            "massive"
          ],
          "default": "auto",
          "description": "Override automatic codebase tier detection. Controls context budget, prompt strategy, and tool behavior. Use 'auto' for automatic detection."
        },
        "webagentCode.agent.maxRounds": {
          "type": "number",
          "default": 25,
          "minimum": 1,
          "maximum": 100,
          "description": "Maximum number of Agent Mode provider/tool rounds before stopping."
        },
        "webagentCode.agent.maxReadBatch": {
          "type": "number",
          "default": 6,
          "minimum": 1,
          "maximum": 12,
          "description": "Maximum number of files Agent Mode should read in one batched read action."
        },
        "webagentCode.agent.autoVerify": {
          "type": "string",
          "enum": [
            "off",
            "after-edits",
            "before-finish"
          ],
          "default": "after-edits",
          "description": "Controls when Agent Mode should prefer verification commands after file changes."
        },
        "webagentCode.playwright.browserChannel": {
          "type": "string",
          "enum": [
            "auto",
            "chrome",
            "msedge",
            "chromium"
          ],
          "default": "auto",
          "description": "Browser channel used for managed Playwright sessions. Auto prefers Chrome/Edge for providers with strict sign-in checks, then falls back to bundled Chromium."
        },
        "webagentCode.mcp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable MCP tool discovery and execution for Agent Mode."
        },
        "webagentCode.mcp.servers": {
          "type": "object",
          "default": {},
          "description": "Additional MCP stdio servers. Shape: { \"name\": { \"command\": \"node\", \"args\": [\"server.js\"], \"env\": {}, \"cwd\": \"optional\" } }. Codex ~/.codex/config.toml MCP servers are also loaded when enabled."
        },
        "webagentCode.mcp.disabledServers": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "uniqueItems": true,
          "description": "MCP server names to hide from Agent Mode prompts and prevent from being called."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "check": "tsc --noEmit",
    "package": "npm run build && vsce package"
  },
  "dependencies": {
    "playwright": "^1.54.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/vscode": "^1.95.0",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.3"
  }
}
